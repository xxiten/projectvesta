# ─────────────────────────────────────────────────────────────────────────────
# Project Vesta — environment template.
# Copy to `.env` for local dev, or provide via the platform secret store (SaaS).
# All values are validated at boot by packages/config (zod) — boot fails fast.
# ─────────────────────────────────────────────────────────────────────────────

# Deployment topology: "saas" (pooled multi-tenant) | "self-host" (single tenant)
VESTA_DEPLOYMENT_MODE=self-host

# Default jurisdiction profile for self-host / first tenant (e.g. IT-BZ = South Tyrol)
VESTA_DEFAULT_JURISDICTION=IT-BZ

# --- API ---
API_PORT=3001
API_BASE_URL=http://localhost:3001
NODE_ENV=development
LOG_LEVEL=debug

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://vesta:vesta@localhost:5432/vesta?schema=public

# --- Redis (queue / cache) ---
REDIS_URL=redis://localhost:6379

# --- Object storage (S3-compatible: MinIO locally) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=eu-central-1
S3_BUCKET=vesta
S3_ACCESS_KEY=vesta
S3_SECRET_KEY=vesta-secret

# --- Auth (internal, behind AuthPort) ---
AUTH_JWT_SECRET=change-me-in-production-min-32-chars-long
AUTH_JWT_TTL=3600

# --- Web ---
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
