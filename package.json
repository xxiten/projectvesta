{
  "name": "vesta",
  "version": "0.0.0",
  "private": true,
  "description": "Project Vesta — modular hotel property-management platform (PMS)",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "boundaries": "depcruise --config .dependency-cruiser.cjs apps packages",
    "format": "prettier --write \"**/*.{ts,tsx,js,cjs,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,cjs,json,md,yaml,yml}\""
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "dependency-cruiser": "^16.8.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
